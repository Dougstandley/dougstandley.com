---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) =>
    import.meta.env.DEV || data.status === 'published'
  );
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);
---

<BaseLayout title={`${essay.data.title} — Doug Standley`}>
  <article>
    <h1>{essay.data.title}</h1>
    <Content />
  </article>
</BaseLayout>
