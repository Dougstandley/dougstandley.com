---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) =>
    import.meta.env.DEV || data.status === 'published'
  );
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

// Resolve references; filter to published targets only (drafts silently hidden).
const referencedEntries = essay.data.references
  ? await Promise.all(essay.data.references.map((ref) => getEntry(ref)))
  : [];
const publishedReferences = referencedEntries.filter(
  (entry) => entry?.data.status === 'published'
);
const forthcoming = essay.data.forthcoming ?? [];
const showGraph = publishedReferences.length > 0 || forthcoming.length > 0;
---

<BaseLayout
  title={`${essay.data.title} — Doug Standley`}
  description={essay.data.description}
>
  <article>
    <h1>{essay.data.title}</h1>
    {essay.data.tags && essay.data.tags.length > 0 && (
      <p class="essay-tags">
        {essay.data.tags.join(' · ')}
      </p>
    )}
    <Content />

    {showGraph && (
      <aside class="essay-graph">
        {publishedReferences.length > 0 && (
          <section class="graph-section">
            <p class="graph-label"><em>Referenced</em></p>
            <ul>
              {publishedReferences.map((ref) => (
                <li><a href={`/essays/${ref.id}`}>{ref.data.title}</a></li>
              ))}
            </ul>
          </section>
        )}
        {forthcoming.length > 0 && (
          <section class="graph-section">
            <p class="graph-label"><em>Forthcoming</em></p>
            <ul>
              {forthcoming.map((item) => (
                <li>
                  {item.title}
                  {item.note && <span class="graph-note"> — {item.note}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    )}
  </article>
</BaseLayout>
