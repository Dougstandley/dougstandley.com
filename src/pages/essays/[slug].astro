---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) =>
    import.meta.env.DEV || data.status === 'published'
  );
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

// Resolve references; filter to published targets only (drafts silently hidden).
const referencedEntries = essay.data.references
  ? await Promise.all(essay.data.references.map((ref) => getEntry(ref)))
  : [];
const publishedReferences = referencedEntries.filter(
  (entry) => entry?.data.status === 'published'
);
const forthcoming = essay.data.forthcoming ?? [];
const showGraph = publishedReferences.length > 0 || forthcoming.length > 0;

// Article JSON-LD. Author refs the Person node on /about by @id.
const canonicalURL = new URL(`/essays/${essay.id}`, Astro.site).toString();
const publishedISO = essay.data.published?.toISOString();
const articleLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: essay.data.title,
  mainEntityOfPage: canonicalURL,
  url: canonicalURL,
  author: {
    '@type': 'Person',
    '@id': 'https://dougstandley.com/about#person',
    name: 'Doug Standley',
    url: 'https://dougstandley.com/about',
  },
};
if (essay.data.description) articleLd.description = essay.data.description;
if (publishedISO) articleLd.datePublished = publishedISO;
if (essay.data.tags && essay.data.tags.length > 0) {
  articleLd.keywords = essay.data.tags.join(', ');
}
---

<BaseLayout
  title={`${essay.data.title} — Doug Standley`}
  description={essay.data.description}
  ogType="article"
  ogImage={`/og/${essay.id}.png`}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(articleLd)}
  />
  <article>
    <h1>{essay.data.title}</h1>
    {essay.data.tags && essay.data.tags.length > 0 && (
      <p class="essay-tags">
        {essay.data.tags.join(' · ')}
      </p>
    )}
    <Content />

    {showGraph && (
      <aside class="essay-graph">
        {publishedReferences.length > 0 && (
          <section class="graph-section">
            <h2 class="graph-label"><em>Referenced</em></h2>
            <ul>
              {publishedReferences.map((ref) => (
                <li><a href={`/essays/${ref.id}`}>{ref.data.title}</a></li>
              ))}
            </ul>
          </section>
        )}
        {forthcoming.length > 0 && (
          <section class="graph-section">
            <h2 class="graph-label"><em>Forthcoming</em></h2>
            <ul>
              {forthcoming.map((item) => (
                <li>
                  {item.title}
                  {item.note && <span class="graph-note"> — {item.note}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    )}

    <aside class="author-chip">
      <p class="author-name">Doug Standley</p>
      <p class="author-bio">
        Writes <em>No Lifeguard on Duty</em> on transitions, agentic AI, and the gap between what technology can do and what institutions can absorb. <a href="/about" class="author-about">About&nbsp;→</a>
      </p>
    </aside>
  </article>
</BaseLayout>
