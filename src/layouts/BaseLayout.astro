---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
}

const { title, description, ogType = 'website' } = Astro.props;

// Canonical URL is the page's pathname resolved against the configured site origin.
// `Astro.site` is set to 'https://dougstandley.com' in astro.config.mjs.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  {description && <meta property="og:description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Inter:wght@400;500&display=swap"
    rel="stylesheet"
  />
  <slot name="head" />
</head>
<body>
  <header>
    <div class="topbar">
      <a href="/" class="wordmark">Doug&nbsp;&nbsp;Standley</a>
      <nav class="nav">
        <a href="/">Essays</a>
        <a href="/about">About</a>
      </nav>
    </div>
    <div class="fullrule"></div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; 2026 Doug Standley</p>
  </footer>
</body>
</html>
