---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  /** Path to a page-specific share card (e.g. /og/<slug>.png). Falls back to the site card. */
  ogImage?: string;
}

const { title, description, ogType = 'website', ogImage } = Astro.props;

// Canonical URL is the page's pathname resolved against the configured site origin.
// `Astro.site` is set to 'https://dougstandley.com' in astro.config.mjs.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// OG / Twitter share image. PNG (1200x630) — SVG share images are not rendered by
// LinkedIn, X, Facebook, iMessage, Slack, or most platforms, so we ship a raster card.
// Per-page cards (essays) pass `ogImage`; everything else uses the site card.
const ogImageURL = new URL(ogImage ?? '/og-card.png', Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Doug Standley" href="/rss.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Doug Standley" />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@DougStandley" />
  <meta name="twitter:creator" content="@DougStandley" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImageURL} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Inter:wght@400;500&display=swap"
    rel="stylesheet"
  />
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header>
    <div class="topbar">
      <a href="/" class="wordmark">Doug&nbsp;&nbsp;Standley</a>
      <nav class="nav" aria-label="Primary">
        <a href="/essays">Essays</a>
        <a href="/map">Map</a>
        <a href="/about">About</a>
      </nav>
    </div>
    <div class="fullrule"></div>
  </header>
  <main id="main">
    <slot />
  </main>
  <footer>
    <p class="footer-acknowledgment">Acknowledgments: Written with the assistance of several frontier AI systems, ongoing human conversations, live music, long walks, and the persistent instability of the modern world.</p>
    <p class="footer-copyright">&copy; 2026 Doug Standley</p>
  </footer>
</body>
</html>
